{
  "name": "fateweaver-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:server": "powershell -ExecutionPolicy Bypass -File scripts/dev-server.ps1 start",
    "dev:status": "powershell -ExecutionPolicy Bypass -File scripts/dev-server.ps1 status",
    "dev:stop": "powershell -ExecutionPolicy Bypass -File scripts/dev-server.ps1 stop",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:ui": "playwright test"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "@vitejs/plugin-react": "^4.3.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "@playwright/test": "^1.60.0",
    "vitest": "^2.1.3"
  }
}
